# BudgetHunter Backend - Environment Variables
# Copy this file to .env and fill with your actual values
# DO NOT commit .env to Git!

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# PostgreSQL password for production
# Generate a secure random password (at least 32 characters)
# Example: openssl rand -base64 32
DATABASE_PASSWORD=your_secure_database_password_here

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
# Application HTTP port (default: 8080)
APP_PORT=8080

# ==============================================
# JWT CONFIGURATION
# ==============================================
# JWT secret key for token signing
# MUST be at least 256 bits (32 bytes) for HS256
# Generate with: openssl rand -base64 64
JWT_SECRET=your_secure_jwt_secret_key_at_least_64_characters_long_here

# JWT access token expiration in milliseconds (default: 24 hours)
# 86400000 ms = 24 hours
JWT_EXPIRATION=86400000

# JWT refresh token expiration in milliseconds (default: 7 days)
# 604800000 ms = 7 days
JWT_REFRESH_EXPIRATION=604800000

# ==============================================
# SPRING PROFILES
# ==============================================
# Active profile: debug (development) or production
# - debug: Uses H2 in-memory database, verbose logging
# - production: Uses PostgreSQL, minimal logging
SPRING_PROFILES_ACTIVE=production

# ==============================================
# HOW TO USE
# ==============================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate secure secrets:
#    DATABASE_PASSWORD: openssl rand -base64 32
#    JWT_SECRET: openssl rand -base64 64
#
# 3. Edit .env and replace placeholder values with the generated secrets
#
# 4. Never commit .env to Git (it's already in .gitignore)
